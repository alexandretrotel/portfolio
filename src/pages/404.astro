---
import Layout from "@/layouts/Layout.astro";

export const prerender = true;
---

<Layout title="Not Found | Alexandre Trotel">
  <div class="flex min-h-[calc(100vh-8rem)] flex-col items-center justify-center gap-4">
    <div class="flex flex-col items-center justify-center">
      <p class="text-muted-foreground text-base">This page does not exist.</p>
    </div>
    <a
      href="/"
      class="rounded-md px-3 py-2 text-sm text-foreground transition-colors hover:bg-accent hover:text-accent-foreground active:scale-90"
    >
      Go back
    </a>
  </div>
</Layout>
