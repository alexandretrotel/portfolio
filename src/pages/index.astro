---
import Layout from "@/layouts/Layout.astro";

export const prerender = true;

const metadata = {
    description:
        "Alexandre Trotel builds tools for complex systems, open source software, and prediction market intelligence.",
    title: "Alexandre Trotel",
};

const linkClass =
    "font-medium text-foreground decoration-border/80 decoration-[0.06em] underline underline-offset-[0.18em] transition-colors hover:text-muted-foreground";
---

<Layout title={metadata.title} description={metadata.description}>
    <section class="mx-auto flex h-full w-full max-w-152 flex-col py-1">
        <div class="space-y-5">
            <div
                class="space-y-3.5 text-[0.9375rem] leading-[1.85] text-muted-foreground"
            >
                <p>
                    I believe that taking action is the best way to experience
                    life. Thus, I've chosen to constantly build, explore, and
                    experiment new things.
                </p>
                <p>
                    I am the co-founder of <a
                        class={linkClass}
                        href="https://www.radion.app"
                        rel="noreferrer"
                        target="_blank">Radion</a
                    >, where our goal is to help prediction market traders make
                    better decisions by providing transparent & interpretable
                    data.
                </p>
                <p>
                    I also created <a
                        class={linkClass}
                        href="https://www.zapstudio.dev"
                        rel="noreferrer"
                        target="_blank">Zap Studio</a
                    >, an open-source initiative for type-safe TypeScript
                    libraries that work across any stacks, so developers gain
                    the freedom to move between tools more easily, with
                    projects like <a
                        class={linkClass}
                        href="https://www.zapstudio.dev/packages/validation"
                        rel="noreferrer"
                        target="_blank">validation</a
                    >, <a
                        class={linkClass}
                        href="https://www.zapstudio.dev/packages/fetch"
                        rel="noreferrer"
                        target="_blank">fetch</a
                    >, <a
                        class={linkClass}
                        href="https://www.zapstudio.dev/packages/permit"
                        rel="noreferrer"
                        target="_blank">permit</a
                    >, <a
                        class={linkClass}
                        href="https://www.zapstudio.dev/packages/retry"
                        rel="noreferrer"
                        target="_blank">retry</a
                    >, and <a
                        class={linkClass}
                        href="https://www.zapstudio.dev/packages/webhooks"
                        rel="noreferrer"
                        target="_blank">webhooks</a
                    >.
                </p>
                <p>I also maintain some tools under licenses like GPL-3.0:</p>
                <ul
                    class="list-disc space-y-1.5 pl-5 marker:text-muted-foreground"
                >
                    <li class="pl-1">
                        <a
                            class={linkClass}
                            href="https://github.com/alexandretrotel/todo-tree"
                            rel="noreferrer"
                            target="_blank">todo-tree</a
                        > finds and displays TODO-style comments in your codebase.
                    </li>
                    <li class="pl-1">
                        <a
                            class={linkClass}
                            href="https://github.com/alexandretrotel/mntn"
                            rel="noreferrer"
                            target="_blank">mntn</a
                        > is a command-line tool to manage your dotfiles with optional
                        encryption support.
                    </li>
                    <li class="pl-1">
                        <a
                            class={linkClass}
                            href="https://github.com/alexandretrotel/feedyourai"
                            rel="noreferrer"
                            target="_blank">fyai</a
                        > combines text files or Git repositories for AI processing
                        with filtering options.
                    </li>
                </ul>
                <p>
                    Outside of code, I like learning about investing my money &
                    understanding topics such as psychology, philosophy, and
                    science. I also do music production, watch anime, read
                    books, and play badminton.
                </p>
            </div>
        </div>
    </section>
</Layout>
