---
import Layout from "@/layouts/Layout.astro";

export const prerender = true;

const metadata = {
  description:
    "Alexandre Trotel builds tools for complex systems, open source software, and prediction market intelligence.",
  title: "Alexandre Trotel",
};

const linkClass =
  "font-medium text-foreground decoration-border/80 decoration-[0.06em] underline underline-offset-[0.18em] transition-colors hover:text-muted-foreground";
---

<Layout title={metadata.title} description={metadata.description}>
  <section class="mx-auto flex h-full w-full max-w-152 flex-col py-1">
    <div class="space-y-5">
      <h1
        class="font-sans text-[1.0625rem] leading-6 font-semibold text-foreground"
      >
        Alexandre Trotel
      </h1>
      <div
        class="space-y-3.5 text-[0.9375rem] leading-[1.85] text-muted-foreground"
      >
        <p>
          I believe the world becomes clear through action, which is why I
          constantly build, explore, and experiment.
        </p>
        <p>
          I am the co-founder of <a
            class={linkClass}
            href="https://www.radion.app"
            rel="noreferrer"
            target="_blank">Radion</a
          >, where we turn prediction market activity into clear market and
          trader intelligence. Our goal is to help traders make better decisions
          with transparent data that is easy to read.
        </p>
        <p>
          I also run <a
            class={linkClass}
            href="https://www.zapstudio.dev"
            rel="noreferrer"
            target="_blank">Zap Studio</a
          >, a side project for type-safe TypeScript libraries that work across
          stacks, so developers can move between tools more easily.
        </p>
        <p>Through Zap Studio:</p>
        <ul class="list-disc space-y-1.5 pl-5 marker:text-muted-foreground">
          <li class="pl-1">
            <a
              class={linkClass}
              href="https://www.zapstudio.dev/packages/validation"
              rel="noreferrer"
              target="_blank">validation</a
            > provides Standard Schema utilities and validation error helpers.
          </li>
          <li class="pl-1">
            <a
              class={linkClass}
              href="https://www.zapstudio.dev/packages/fetch"
              rel="noreferrer"
              target="_blank">fetch</a
            > is a type-safe fetch wrapper with Standard Schema validation.
          </li>
          <li class="pl-1">
            <a
              class={linkClass}
              href="https://www.zapstudio.dev/packages/permit"
              rel="noreferrer"
              target="_blank">permit</a
            > is a type-safe authorization library for TypeScript with Standard
            Schema support.
          </li>
          <li class="pl-1">
            <a
              class={linkClass}
              href="https://www.zapstudio.dev/packages/webhooks"
              rel="noreferrer"
              target="_blank">webhooks</a
            > provides type-safe webhook routing with signature verification.
          </li>
        </ul>
        <p>I also maintain some tools under licenses like GPL-3.0:</p>
        <ul class="list-disc space-y-1.5 pl-5 marker:text-muted-foreground">
          <li class="pl-1">
            <a
              class={linkClass}
              href="https://github.com/alexandretrotel/todo-tree"
              rel="noreferrer"
              target="_blank">todo-tree</a
            > finds and displays TODO-style comments in your codebase.
          </li>
          <li class="pl-1">
            <a
              class={linkClass}
              href="https://github.com/alexandretrotel/mntn"
              rel="noreferrer"
              target="_blank">mntn</a
            > is a command-line tool to manage your dotfiles.
          </li>
          <li class="pl-1">
            <a
              class={linkClass}
              href="https://github.com/alexandretrotel/feedyourai"
              rel="noreferrer"
              target="_blank">fyai</a
            > combines text files for AI processing with filtering options.
          </li>
        </ul>
        <p>
          Outside of code, I like learning about software, investment,
          psychology, philosophy, and science. I also do music production, watch
          anime, read books, and play badminton.
        </p>
      </div>
    </div>
  </section>
</Layout>
