---
import ItemList from "@/core/features/home/components/item-list.astro";

interface LatestBlogItem {
  name: string;
  url: string;
  yearLabel: string;
  yearValue: string;
}

interface Props {
  posts: LatestBlogItem[];
}

const props = Astro.props as Props;
const { posts } = props;
---

<section>
  {posts.length > 0 ? (
    <ItemList items={posts} linkTarget="_self" linkRel={undefined} />
  ) : (
    <p class="text-sm leading-relaxed text-muted-foreground">
      New posts will appear here.
    </p>
  )}
</section>
