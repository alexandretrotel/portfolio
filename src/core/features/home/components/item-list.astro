---
interface Item {
  name: string;
  url?: string;
  yearLabel: string;
  yearValue: string;
}

interface Props {
  items: Item[];
  linkRel?: string;
  linkTarget?: string;
}
const props = Astro.props as Props;
const { items, linkTarget = "_blank", linkRel = "noreferrer" } = props;
---

<ul class="space-y-6">
  {items.map((item, index) => (
    <li class={index > 0 && item.yearLabel ? "pt-8 sm:pt-10" : undefined}>
      {item.url ? (
        <a
          aria-label={`${item.name} (${item.yearValue})`}
          class="group grid gap-1 transition-colors sm:grid-cols-[5rem_minmax(0,1fr)] sm:gap-x-8"
          href={item.url}
          rel={linkRel}
          target={linkTarget}
        >
          <span class="text-xs text-muted-foreground sm:pt-0.5">
            {item.yearLabel}
          </span>
          <p class="font-serif text-[0.95rem] leading-snug text-foreground transition-colors group-hover:text-muted-foreground group-focus:text-muted-foreground sm:text-[1.05rem]">
            {item.name}
          </p>
        </a>
      ) : (
        <div class="grid gap-1 sm:grid-cols-[5rem_minmax(0,1fr)] sm:gap-x-8">
          <span class="text-xs text-muted-foreground sm:pt-0.5">
            {item.yearLabel}
          </span>
          <p class="font-serif text-[0.95rem] leading-snug text-foreground sm:text-[1.05rem]">
            {item.name}
          </p>
        </div>
      )}
    </li>
  ))}
</ul>
