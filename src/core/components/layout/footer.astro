---
import { cn } from "@/core/primitives/utils/cn";

const linkClass = cn(
  "transition-colors",
  "text-foreground/70",
  "hover:text-foreground"
);

const links = [
  {
    external: true,
    href: "https://www.github.com/alexandretrotel",
    label: "GitHub",
  },
];
---

<footer class="w-full bg-background">
  <div class="mx-auto flex h-16 max-w-3xl items-center justify-end">
    <nav class="flex items-center gap-5 text-sm text-muted-foreground">
      {links.map((link) => (
        <a
          class={linkClass}
          href={link.href}
          rel={link.external ? "noreferrer" : undefined}
          target={link.external ? "_blank" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</footer>
