---
import "@/styles/globals.css";
import "@fontsource-variable/inter";

import Header from "@/core/components/layout/header.astro";
import { METADATA } from "@/core/primitives/constants/metadata";

interface Props {
    description?: string;
    title?: string;
}

const defaultMetadata = {
    description: METADATA.DESCRIPTION,
    title: METADATA.TITLE,
};

const props = Astro.props as Props;
const {
    title = defaultMetadata.title,
    description = defaultMetadata.description,
} = props;

const ogLocale = "en_US";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:locale" content={ogLocale} />
        <meta property="og:url" content={Astro.url.href} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />

        <!-- Twitter -->
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />

        <link rel="icon" type="image/png" href="/logo.png" />
        <title>{title}</title>

        <!-- Sitemap -->
        <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    </head>
    <body class="antialiased">
        <div class="min-h-screen bg-background px-6">
            <Header />
            <main
                class="mx-auto min-h-[calc(100vh-8rem)] max-w-152 py-12 md:py-18"
            >
                <slot />
            </main>
        </div>
    </body>
</html>
